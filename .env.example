# 前端环境变量
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=cost:api:

# 缓存 TTL 配置（秒）
REDIS_TTL_DASHBOARD=300      # 仪表盘数据 5分钟
REDIS_TTL_BASEDATA=600       # 基础数据 10分钟
REDIS_TTL_SESSION=604800     # 会话 7天
REDIS_TTL_DEFAULT=300        # 默认 5分钟
